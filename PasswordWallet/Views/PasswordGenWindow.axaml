<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PasswordWallet.Views.PasswordGenWindow"
        Title="Password Generator"
        Width="700"
        Height="550"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F">

    <Border Background="#2A2A40"
            CornerRadius="20"
            Margin="25"
            Padding="30">

        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="🔐 Password Generator"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="White"
                       Margin="0,0,0,25"/>

            <!-- Length -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="15"
                        Margin="0,10">

                <TextBlock Text="Password Length"
                           Width="170"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="16"/>

                <TextBox x:Name="LengthTextBox"
                         Width="120"
                         Watermark="16"/>
            </StackPanel>

            <!-- Options -->
            <StackPanel Grid.Row="2"
                        Margin="0,20">

                <CheckBox x:Name="UpperCaseCheckBox"
                          Content="Include Uppercase Letters (A-Z)"
                          Foreground="White"
                          Margin="0,5"/>

                <CheckBox x:Name="LowerCaseCheckBox"
                          Content="Include Lowercase Letters (a-z)"
                          Foreground="White"
                          Margin="0,5"/>

                <CheckBox x:Name="NumberCheckBox"
                          Content="Include Numbers (0-9)"
                          Foreground="White"
                          Margin="0,5"/>

                <CheckBox x:Name="SymbolCheckBox"
                          Content="Include Symbols (!@#$%)"
                          Foreground="White"
                          Margin="0,5"/>
            </StackPanel>

            <!-- Generate Button -->
            <Button Grid.Row="3"
                    Content="Generate Password"
                    Height="45"
                    Margin="0,25,0,20"
                    Background="#4F46E5"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    Click="GeneratePassword_Click"/>

            <!-- Generated Password -->
            <TextBlock Grid.Row="4"
                       Text="Generated Password"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,10,0,8"/>

            <TextBox Grid.Row="5"
                     x:Name="GeneratedPasswordTextBox"
                     IsReadOnly="True"
                     FontSize="18"
                     FontWeight="SemiBold"
                     HorizontalContentAlignment="Center"/>

            <!-- Bottom Buttons -->
            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="20"
                        Margin="0,30">

                <Button Content="📋 Copy"
                        Width="140"
                        Height="42"
                        Background="#10B981"
                        Foreground="White"
                        Click="CopyPassword_Click"/>

                <Button Content="⬅ Back"
                        Width="140"
                        Height="42"
                        Background="#EF4444"
                        Foreground="White"
                        Click="BackButton_Click"/>
            </StackPanel>

        </Grid>

    </Border>

</Window>