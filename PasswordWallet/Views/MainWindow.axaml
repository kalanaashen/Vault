<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="PasswordWallet.Views.MainWindow"
    xmlns:models="using:PasswordWallet.Models"
    Width="850"
    Height="650"
    MinWidth="650"
    MinHeight="500"
    Title="Password Wallet">

    <Grid
        Margin="30"
        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*"
        ColumnDefinitions="140,*"
        RowSpacing="15"
        ColumnSpacing="15">

        <!-- Application title -->
        <TextBlock
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Text="Password Wallet"
            FontSize="30"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0,0,0,20"/>

        <!-- Website -->
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Text="Website:"
            VerticalAlignment="Center"/>

        <TextBox
            x:Name="WebsiteTextBox"
            Grid.Row="1"
            Grid.Column="1"
            Watermark="Example: github.com"/>

        <!-- Username -->
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Text="Username:"
            VerticalAlignment="Center"/>

        <TextBox
            x:Name="UsernameTextBox"
            Grid.Row="2"
            Grid.Column="1"
            Watermark="Enter username or email"/>

        <!-- Password -->
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Text="Password:"
            VerticalAlignment="Center"/>

        <TextBox
            x:Name="PasswordTextBox"
            Grid.Row="3"
            Grid.Column="1"
            PasswordChar="●"
            Watermark="Enter password"/>

        <!-- Save button -->
        <Button
            Grid.Row="4"
            Grid.Column="1"
            Content="Save Password"
            HorizontalAlignment="Left"
            Click="SaveButton_Click"/>

        <!-- Status message -->
        <TextBlock
            x:Name="MessageTextBlock"
            Grid.Row="5"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            FontWeight="SemiBold"/>

        <!-- Password list -->
        <Border
            Grid.Row="6"
            Grid.ColumnSpan="2"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="8"
            Padding="15">

            <Grid RowDefinitions="Auto,*" RowSpacing="15">

                <TextBlock
                    Grid.Row="0"
                    Text="Saved Passwords"
                    FontSize="20"
                    FontWeight="Bold"/>

                <ListBox
                    x:Name="PasswordList"
                    Grid.Row="1">

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:PasswordEntry">
                            <Border
                                BorderBrush="#555555"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,0,0,10">

                                <Grid
                                    ColumnDefinitions="120,*"
                                    RowDefinitions="Auto,Auto,Auto"
                                    RowSpacing="8"
                                    ColumnSpacing="10">

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Text="Website:"
                                        FontWeight="Bold"/>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Text="{Binding Website}"/>

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Text="Username:"
                                        FontWeight="Bold"/>

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding Username}"/>

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Text="Password:"
                                        FontWeight="Bold"/>

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Text="{Binding Password}"/>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
            </Grid>
        </Border>

    </Grid>
</Window>