<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="PasswordWallet.Views.LoginWindow"
    Width="900"
    Height="600"
    MinWidth="700"
    MinHeight="500"
    Title="Password Wallet"
    Background="#111827">

    <Grid>

        <!-- Background decoration -->
        <Ellipse
            Width="320"
            Height="320"
            Fill="#1D4ED8"
            Opacity="0.18"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="-100,-120,0,0"/>

        <Ellipse
            Width="380"
            Height="380"
            Fill="#7C3AED"
            Opacity="0.15"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,-130,-150"/>

        <!-- Login card -->
        <Border
            Width="390"
            Padding="32"
            Background="#1F2937"
            BorderBrush="#374151"
            BorderThickness="1"
            CornerRadius="18"
            BoxShadow="0 18 45 0 #70000000"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Spacing="18">

                <!-- Logo -->
                <Border
                    Width="64"
                    Height="64"
                    Background="#2563EB"
                    CornerRadius="18"
                    HorizontalAlignment="Center">

                    <TextBlock
                        Text="🔐"
                        FontSize="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Spacing="6">

                    <TextBlock
                        Text="Welcome Back"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="White"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        Text="Sign in to access your password wallet"
                        FontSize="14"
                        Foreground="#9CA3AF"
                        HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Username -->
                <StackPanel Spacing="7">

                    <TextBlock
                        Text="Username"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#D1D5DB"/>

                    <TextBox
                        x:Name="UsernameTextBox"
                        Height="45"
                        Padding="14,0"
                        Background="#111827"
                        Foreground="White"
                        BorderBrush="#4B5563"
                        BorderThickness="1"
                        CornerRadius="10"
                        PlaceholderText="Enter your username"/>
                </StackPanel>

                <!-- Password -->
                <StackPanel Spacing="7">

                    <TextBlock
                        Text="Password"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#D1D5DB"/>

                    <TextBox
                        x:Name="PasswordTextBox"
                        Height="45"
                        Padding="14,0"
                        Background="#111827"
                        Foreground="White"
                        BorderBrush="#4B5563"
                        BorderThickness="1"
                        CornerRadius="10"
                        PasswordChar="●"
                        PlaceholderText="Enter your password"/>
                </StackPanel>

                <!-- Login button -->
                <Button
                    Height="46"
                    Margin="0,8,0,0"
                    Content="Login"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Background="#2563EB"
                    CornerRadius="10"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="LoginButton_Click"/>

                <!-- Message -->
                <TextBlock
                    x:Name="MessageTextBlock"
                    FontSize="14"
                    Foreground="#F87171"
                    TextAlignment="Center"
                    TextWrapping="Wrap"/>

                <!-- Footer -->
                <TextBlock
                    Text="Securely manage your credentials"
                    FontSize="12"
                    Foreground="#6B7280"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>