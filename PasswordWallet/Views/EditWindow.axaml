<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="PasswordWallet.Views.EditWindow"
    Width="800"
    Height="500"
    MinWidth="800"
    MinHeight="500"
    Title="Edit Details"
    Background="#111827">
    

    <Grid Margin="20" RowDefinitions="*,Auto">

    
        <StackPanel Grid.Row="0" Spacing="12">
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="#D1D5DB"
                Text="Edit Details" 
                Margin="0,0,0,15"/>
            
            <TextBlock Text="Website"  Foreground="#9CA3AF" FontSize="13"/>
            <TextBox Height="36" x:Name="WebsiteTextBox" Background="#1F2937" Foreground="White" BorderBrush="#374151"/>
            
            <TextBlock Text="Username" Foreground="#9CA3AF" FontSize="13" Margin="0,8,0,0"/>
            <TextBox Height="36" x:Name="UsernameTextBox" Background="#1F2937" Foreground="White" BorderBrush="#374151"/>
            
            <TextBlock Text="Password" Foreground="#9CA3AF" FontSize="13" Margin="0,8,0,0"/>
            <TextBox Height="36" x:Name="PasswordTextBox" PasswordChar="•" Background="#1F2937" Foreground="White" BorderBrush="#374151"/>
        </StackPanel>
        
      
        <Button
            Grid.Row="1"       
            Content="Confirm Edit" 
            HorizontalAlignment="Right"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Padding="16,8"
            Click="ConfrimButton_Click"
            Background="#2563EB"
            Foreground="White"
            CornerRadius="6"
            Margin="0,20,0,0"/>
    </Grid>
</Window>